<!DOCTYPE html>
<html lang="en" class="<%= theme === 'dark' ? 'dark' : '' %>" data-theme="<%= theme || 'light' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'System Error' %></title>
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/darkmode.css">
    <link rel="stylesheet" href="/css/setup-error.css">
</head>
<body>
    <div class="error-container">
        <div class="error-icon">⚠️</div>
        <h1><%= title %></h1>

        <div class="error-message">
            <strong>Error Details:</strong><br>
            <%= errorMessage %>
        </div>

        <div class="admin-notice">
            🔒 This is an administrative error state. Setup page is disabled to protect your configuration.
        </div>

        <div class="support-text">
            <strong>What to do:</strong><br>
            <%= supportText %>
        </div>

        <div class="action-buttons">
            <button onclick="location.reload()" class="btn btn-secondary">Retry Connection</button>
            <a href="/" class="btn btn-primary">Return Home</a>
        </div>

        <div class="tech-details">
            <p>Status: System Configuration Error | Contact your administrator if this persists.</p>
        </div>
    </div>
</body>
</html>
