<meta name="color-scheme" content="light dark">
<script>
    (function () {
        const STORAGE_KEY = 'theme';
        const COOKIE_KEY = 'theme';
        const COOKIE_MAX_AGE = 60 * 60 * 24 * 365;

        function normalizeTheme(value) {
            return value === 'dark' ? 'dark' : 'light';
        }

        function applyTheme(theme) {
            const resolvedTheme = normalizeTheme(theme);
            const root = document.documentElement;

            root.setAttribute('data-theme', resolvedTheme);
            root.classList.toggle('dark', resolvedTheme === 'dark');
            root.style.colorScheme = resolvedTheme;

            try {
                window.localStorage.setItem(STORAGE_KEY, resolvedTheme);
            } catch (_error) {
                // Ignore storage failures and keep the in-memory theme.
            }

            try {
                let cookieValue = `${COOKIE_KEY}=${resolvedTheme}; Path=/; Max-Age=${COOKIE_MAX_AGE}; SameSite=Lax`;
                if (window.location && window.location.protocol === 'https:') {
                    cookieValue += '; Secure';
                }
                document.cookie = cookieValue;
            } catch (_error) {
                // Ignore cookie write failures.
            }

            return resolvedTheme;
        }

        function getCookieTheme() {
            if (typeof document === 'undefined') {
                return null;
            }

            const cookieMatch = document.cookie
                .split('; ')
                .find((entry) => entry.startsWith(`${COOKIE_KEY}=`));

            if (!cookieMatch) {
                return null;
            }

            const value = cookieMatch.split('=')[1];
            return normalizeTheme(value);
        }

        function getStoredTheme() {
            const cookieTheme = getCookieTheme();
            if (cookieTheme) {
                return cookieTheme;
            }

            try {
                return normalizeTheme(window.localStorage.getItem(STORAGE_KEY));
            } catch (_error) {
                return 'light';
            }
        }

        window.__paperlessAiApplyTheme = applyTheme;
        window.__paperlessAiGetTheme = getStoredTheme;

        applyTheme(getStoredTheme());
    })();
</script>
